[Unit]
Description=automem API
After=network-online.target docker.service ollama.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/automem
EnvironmentFile=/opt/automem/backend/.env
ExecStart=/opt/automem/.venv/bin/uvicorn backend.main:app --host ${BIND_HOST} --port ${BIND_PORT}
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
