[Unit]
Description=automem daily consolidation
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/automem
EnvironmentFile=/opt/automem/backend/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/automem/.venv/bin/python /opt/automem/scripts/scheduled_consolidate.py
SyslogIdentifier=automem-consolidate
StandardOutput=journal
StandardError=journal
