ADMIN_API_KEY=change-me-admin-key
TASK_DB_PATH=/var/lib/automem/tasks.db
ZAI_API_KEY=change-me-zai-key
ZAI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
ZAI_MODEL=glm-5
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_DIMS=768
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_COLLECTION=mem0
MEM0_TELEMETRY=False
AUTOMEM_DISABLE_QDRANT_PAYLOAD_INDEXES=False
HISTORY_DB_PATH=/var/lib/automem/history.db
BIND_HOST=127.0.0.1
BIND_PORT=8888
DEFAULT_MEMORY_USER_ID=example-user
DEFAULT_MEMORY_AGENT_ID=agent-default
AUTOMEM_WORKER_ID=automem-worker@example-host
AUTOMEM_WORKER_POLL_SECONDS=5
AUTOMEM_WORKER_ONCE=false
AUTOMEM_WORKER_LOG_LEVEL=INFO
AUTOMEM_WORKER_REQUEST_TIMEOUT_SECONDS=900
AUTOMEM_WORKER_LOCK_FILE=/var/lib/automem/tasks.worker.lock
